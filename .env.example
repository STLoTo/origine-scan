PORT=3001

# AI — Ollama locale (consigliato)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_OCR_MODEL=glm-ocr:latest
# Fallback vision se glm-ocr fallisce (qwen3.5, llava, ecc.)
OLLAMA_OCR_FALLBACK_MODEL=qwen3.5:4b
LLM_TIMEOUT_MS=90000

# OpenAI cloud (alternativa)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Banche dati opzionali
SERP_API_KEY=
UN_COMTRADE_API_KEY=

REQUEST_TIMEOUT_MS=12000
